@startuml activity-diagram
skinparam shadowing false
skinparam ActivityBackgroundColor white
skinparam ActivityBorderColor black
skinparam ActivityFontSize 13
skinparam ArrowColor black

start

:Авторизоваться в приложении;

if (Нет аккаунта?) then (да)
  :Зарегистрироваться;
  :Ввести логин;
  :Ввести пароль;
else (нет)
  :Войти в аккаунт;
  :Ввести логин;
  :Ввести пароль;
  while (Пароль верный?) is (нет)
    :Повторить ввод логина и пароля;
  endwhile (да)
endif

:Открыть страницу «Мои фото»;

repeat

fork
  :Открыть форму загрузки;
  :Выбрать файлы;
  :Указать теги;
  :Загрузить изображения;
fork again
  :Запустить автотегирование;
  :Выполнить классификацию (ResNet);
  :Просмотреть статус автотегирования;
fork again
  if (Тип операции?) then (поиск)
    :Ввести название или тег;
    :Просмотреть результаты поиска;
  elseif (похожие) then
    if (Способ поиска?) then (образец)
      :Загрузить образец;
    else (участок)
      :Выделить область на изображении;
    endif
    :Просмотреть похожие изображения;
  else (управление)
    :Редактировать теги;
    :Удалить изображение;
  endif
end fork

repeat while (Продолжить работу?) is (да)
->нет;

:Выйти из аккаунта;

stop

@enduml
